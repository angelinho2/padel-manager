# ────────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores
# cp .env.example .env
# ────────────────────────────────────────────────

# Base de datos SQLite (ruta dentro del contenedor)
DATABASE_URL=sqlite:////app/data/padel.db

# Seguridad JWT — CAMBIA ESTO antes de poner en producción
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion

# Credenciales del administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Modo debug (True muestra las queries SQL en los logs)
DEBUG=False
